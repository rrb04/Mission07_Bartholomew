@model Mission07_Bartholomew.Models.Movie

@{
    // Dynamically change the title based on if we are adding or editing
    ViewData["Title"] = Model.MovieId == 0 ? "Add a Movie" : "Edit Movie";
}

<h2>@ViewData["Title"]</h2>

<form method="post" asp-action="@(Model.MovieId == 0 ? "MovieForm" : "Edit")">

    <input type="hidden" asp-for="MovieId" />

    <div class="form-group mb-3">
        <label asp-for="CategoryId">Category:</label>
        <select asp-for="CategoryId" class="form-control" required>
            <option value="">Select a Category...</option>
            @foreach (var c in ViewBag.Categories)
            {
                <option value="@c.CategoryId">@c.CategoryName</option>
            }
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Title">Title:</label>
        <input asp-for="Title" class="form-control" required />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Year">Year:</label>
        <input asp-for="Year" type="number" class="form-control" required />
        <span asp-validation-for="Year" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Director">Director:</label>
        <input asp-for="Director" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Rating">Rating:</label>
        <select asp-for="Rating" class="form-control">
            <option value="">Select a Rating...</option>
            <option value="G">G</option>
            <option value="PG">PG</option>
            <option value="PG-13">PG-13</option>
            <option value="R">R</option>
            <option value="NR">NR</option>
            <option value="UR">UR</option>
        </select>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Edited">Edited?</label>
        <select asp-for="Edited" class="form-control" required>
            <option value="false">No</option>
            <option value="true">Yes</option>
        </select>
    </div>

    <div class="form-group mb-3">
        <label asp-for="LentTo">Lent To (Optional):</label>
        <input asp-for="LentTo" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="CopiedToPlex">Copied to Plex?</label>
        <select asp-for="CopiedToPlex" class="form-control" required>
            <option value="false">No</option>
            <option value="true">Yes</option>
        </select>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Notes">Notes (Max 25 chars):</label>
        <input asp-for="Notes" class="form-control" maxlength="25" />
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <br />
    <button type="submit" class="btn btn-primary">Save Movie</button>
</form>