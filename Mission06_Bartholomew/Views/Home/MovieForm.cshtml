@model Mission06_Bartholomew.Models.Movie

@{
    ViewData["Title"] = "Add a Movie";
}

<h2>Add a Movie to the Collection</h2>
<form method="post">
    <div class="form-group">
        <label asp-for="Category">Category:</label>
        <input asp-for="Category" class="form-control" required />
    </div>
    <div class="form-group">
        <label asp-for="Title">Title:</label>
        <input asp-for="Title" class="form-control" required />
    </div>
    <div class="form-group">
        <label asp-for="Year">Year:</label>
        <input asp-for="Year" class="form-control" required />
    </div>
    <div class="form-group">
        <label asp-for="Director">Director:</label>
        <input asp-for="Director" class="form-control" required />
    </div>
    <div class="form-group">
        <label asp-for="Rating">Rating:</label>
        <select asp-for="Rating" class="form-control" required>
            <option value="">Select a Rating</option>
            <option value="G">G</option>
            <option value="PG">PG</option>
            <option value="PG-13">PG-13</option>
            <option value="R">R</option>
        </select>
    </div>
    <div class="form-group">
        <label asp-for="Edited">Edited?</label>
        <select asp-for="Edited" class="form-control">
            <option value="false">No</option>
            <option value="true">Yes</option>
        </select>
    </div>
    <div class="form-group">
        <label asp-for="LentTo">Lent To (Optional):</label>
        <input asp-for="LentTo" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Notes">Notes (Max 25 chars):</label>
        <input asp-for="Notes" class="form-control" maxlength="25" />
    </div>
    <br />
    <button type="submit" class="btn btn-primary">Add Movie</button>
</form>